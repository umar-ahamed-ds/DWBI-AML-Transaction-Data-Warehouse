      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{7C721070-5032-4790-A2FF-7D001DCF6E8E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update Fact Completion Time"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D897E299-5215-4015-9C69-5BA2E3502745}"
          SQLTask:SqlStatementSource="UPDATE F&#xA;SET&#xA;    F.accm_txn_complete_time = S.accm_txn_complete_time,&#xA;    F.txn_process_time_hours =&#xA;        CAST(DATEDIFF(MINUTE, F.accm_txn_create_time, S.accm_txn_complete_time) AS DECIMAL(18,2)) / 60.0&#xA;FROM dbo.Fact_Transactions F&#xA;INNER JOIN dbo.Stg_FactUpdates S&#xA;    ON F.TransactionID = S.txn_id&#xA;WHERE S.accm_txn_complete_time &gt;= F.accm_txn_create_time;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
