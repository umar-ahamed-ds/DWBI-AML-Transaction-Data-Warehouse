                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    CAST([Time] AS NVARCHAR(20)) AS [Time],
    CAST([Date] AS DATE) AS [Date],
    CAST(Sender_account AS VARCHAR(50)) AS Sender_account,
    CAST(Receiver_account AS VARCHAR(50)) AS Receiver_account,
    CAST(Amount AS DECIMAL(18,2)) AS Amount,
    CAST(Payment_currency AS VARCHAR(50)) AS Payment_currency,
    CAST(Received_currency AS VARCHAR(50)) AS Received_currency,
    CAST(Sender_bank_location AS VARCHAR(50)) AS Sender_bank_location,
    CAST(Receiver_bank_location AS VARCHAR(50)) AS Receiver_bank_location,
    CAST(Payment_type AS VARCHAR(50)) AS Payment_type,
    CASE WHEN Is_laundering IN ('1','True','true') THEN 1 ELSE 0 END AS Is_laundering,
    CAST(Laundering_type AS VARCHAR(100)) AS Laundering_type,
    CAST([timestamp] AS DATETIME2) AS [timestamp],
    CASE WHEN is_suspicious IN ('1','True','true') THEN 1 ELSE 0 END AS is_suspicious
FROM dbo.Transactions_Raw;</property>
