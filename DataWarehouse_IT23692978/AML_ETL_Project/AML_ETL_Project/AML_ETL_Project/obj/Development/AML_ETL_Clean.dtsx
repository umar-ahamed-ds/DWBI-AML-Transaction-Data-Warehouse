    <DTS:Executable
      DTS:refId="Package\Apply SCD to Dim_Location"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{A6B6082F-99F4-4204-A5F6-934673C3AD68}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Apply SCD to Dim_Location"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{69B65804-86FF-4CD7-A775-69A3068E1BC8}"
          SQLTask:SqlStatementSource="-- 1. Expire old current rows if the descriptive value changed&#xA;UPDATE d&#xA;SET&#xA;    d.EndDate = CAST(GETDATE() AS DATE),&#xA;    d.IsCurrent = 0&#xA;FROM dbo.Dim_Location d&#xA;INNER JOIN AML_Staging.dbo.Stg_Location s&#xA;    ON d.Country = s.Country&#xA;WHERE d.IsCurrent = 1&#xA;  AND ISNULL(d.LocationName, '') &lt;&gt; ISNULL(s.LocationName, '');&#xA;&#xA;-- 2. Insert new current rows if:&#xA;--    a) country is brand new, or&#xA;--    b) changed version does not already exist as current&#xA;INSERT INTO dbo.Dim_Location&#xA;(&#xA;    Country,&#xA;    StartDate,&#xA;    EndDate,&#xA;    IsCurrent,&#xA;    LocationName&#xA;)&#xA;SELECT&#xA;    s.Country,&#xA;    CAST(GETDATE() AS DATE) AS StartDate,&#xA;    CAST('9999-12-31' AS DATE) AS EndDate,&#xA;    1 AS IsCurrent,&#xA;    s.LocationName&#xA;FROM AML_Staging.dbo.Stg_Location s&#xA;LEFT JOIN dbo.Dim_Location d&#xA;    ON d.Country = s.Country&#xA;   AND d.IsCurrent = 1&#xA;   AND ISNULL(d.LocationName, '') = ISNULL(s.LocationName, '')&#xA;WHERE d.LocationKey IS NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
