    CAST(GETDATE() AS DATE) AS StartDate,
    CAST('9999-12-31' AS DATE) AS EndDate,
    CAST(1 AS BIT) AS IsCurrent,
    Sender_bank_location AS LocationName
FROM dbo.Stg_Transactions
WHERE Sender_bank_location IS NOT NULL

UNION

SELECT DISTINCT
    Receiver_bank_location AS Country,
    CAST(GETDATE() AS DATE) AS StartDate,
    CAST('9999-12-31' AS DATE) AS EndDate,
    CAST(1 AS BIT) AS IsCurrent,
    Receiver_bank_location AS LocationName
FROM dbo.Stg_Transactions
WHERE Receiver_bank_location IS NOT NULL;</property>
