            <component
              refId="Package\Load Fact_Transactions\source fac base"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="source fac base"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    ROW_NUMBER() OVER (ORDER BY [Date], Sender_account, Receiver_account) AS TransactionID,
    [Date],
    Sender_account,
    Receiver_account,
    Amount,
    Payment_currency,
    Received_currency,
    Sender_bank_location,
    Receiver_bank_location,
    Payment_type,
    Is_laundering,
    is_suspicious,
    GETDATE() AS accm_txn_create_time,
    NULL AS accm_txn_complete_time,
    NULL AS txn_process_time_hours
FROM AML_Staging.dbo.Stg_Transactions
WHERE [Date] IS NOT NULL;</property>
                <property
                  dataType="System.String"
                  description="The variable that contains the SQL command to be executed."
                  name="SqlCommandVariable"></property>
                <property
                  dataType="System.Int32"
                  description="Specifies the column code page to use when code page information is unavailable from the data source."
                  name="DefaultCodePage">1252</property>
                <property
                  dataType="System.Boolean"
