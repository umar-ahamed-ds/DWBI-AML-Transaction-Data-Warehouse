              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="Source - Fact Data"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    s.TransactionID,
    d.DateKey,
    sa.AccountKey AS SenderAccountKey,
    ra.AccountKey AS ReceiverAccountKey,
    pt.PaymentTypeKey,
    c.CurrencyKey,
    sl.LocationKey AS SenderLocationKey,
    rl.LocationKey AS ReceiverLocationKey,
    s.Amount,
    CASE 
        WHEN s.Is_laundering IN ('1', 'True', 'true', 'YES', 'Yes') THEN 1
        ELSE 0
    END AS Is_laundering,
    CASE 
        WHEN s.is_suspicious IN ('1', 'True', 'true', 'YES', 'Yes') THEN 1
        ELSE 0
    END AS Is_suspicious
FROM AML_Staging.dbo.Stg_Transactions s
JOIN AML_DW.dbo.Dim_Date d
    ON d.[Date] = s.[Date]
JOIN AML_DW.dbo.Dim_Account sa
    ON sa.Account_ID = s.Sender_account
JOIN AML_DW.dbo.Dim_Account ra
    ON ra.Account_ID = s.Receiver_account
JOIN AML_DW.dbo.Dim_PaymentType pt
    ON pt.Payment_Type = s.Payment_type
JOIN AML_DW.dbo.Dim_Currency c
    ON c.CurrencyName = s.Payment_currency
JOIN AML_DW.dbo.Dim_Location sl
    ON sl.LocationName = s.Sender_bank_location
JOIN AML_DW.dbo.Dim_Location rl
    ON rl.LocationName = s.Receiver_bank_location;</property>
